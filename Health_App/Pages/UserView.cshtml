@page "/data"
@model Health_App.Pages.UserViewModel
@{
    ViewData["Title"] = "Panel Użytkownika";
}

<nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom mb-4">
    <div class="container">
        <a class="navbar-brand" href="#">HealthApp</a>

        <div class="ms-auto d-flex align-items-center">
            <span class="me-3">Cześć, <strong>@Model._currentUserName</strong>!</span>

            <div class="dropdown">
                <button class="btn btn-secondary dropdown-toggle" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                    Opcje
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                    <li><a class="dropdown-item" asp-page="/EditProfile">Zmień dane</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" asp-page="/Logout">Wyloguj</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<div class="container">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Lista zarejestrowanych użytkowników</h5>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nazwa</th>
                        <th>Surname</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model._usersList != null)
                    {
                        @foreach (var user in Model._usersList)
                        {
                            <tr>
                                <td>@user.name</td>
                                <td>@user.surname</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>